# LexisAI Public — .gitignore

# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Outputs (not committed — generated locally)
demo/screenshots/*.png
demo/demo_outputs/*
!demo/demo_outputs/.gitkeep
!demo/screenshots/.gitkeep

